# Supabase
# Pegue esses valores em https://supabase.com/dashboard -> seu projeto -> Settings -> API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Apenas no servidor (NUNCA exponha no client). Necessaria para o worker local
# de processamento (npm run render).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# URL base do app (usada para gerar links publicos)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nome do bucket de storage no Supabase
NEXT_PUBLIC_SUPABASE_BUCKET=spaces

# === Worker local (npm run render) ===
# Caminho COMPLETO ate o executavel meshroom_batch (parte do Meshroom).
# Windows exemplo: C:\Tools\Meshroom-2023.3.0\meshroom_batch.exe
# Linux exemplo:   /opt/Meshroom-2023.3.0/meshroom_batch
MESHROOM_PATH=
