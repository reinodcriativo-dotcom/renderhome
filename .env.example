# Supabase
# Pegue esses valores em https://supabase.com/dashboard -> seu projeto -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Apenas no servidor (NUNCA exponha no client). Necessária para o worker de processamento mockado.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# URL base do app (usada para gerar links públicos)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nome do bucket de storage no Supabase
NEXT_PUBLIC_SUPABASE_BUCKET=spaces
