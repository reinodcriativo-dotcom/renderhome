# Supabase
# Pegue esses valores em https://supabase.com/dashboard -> seu projeto -> Settings -> API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Apenas no servidor (NUNCA exponha no client). Usada em rotas de servidor
# que precisam bypassar RLS.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# URL base do app (usada para gerar links do QR)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nome do bucket de storage no Supabase
NEXT_PUBLIC_SUPABASE_BUCKET=spaces
